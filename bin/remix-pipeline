#!/usr/bin/env bash
#
# remix-pipeline — Full DAS remix orchestrator
#
# Searches Tidal, downloads HQ audio, analyzes BPM/key, splits stems,
# scaffolds Ableton project, and generates analysis visualizations.
#
# Usage:
#   remix-pipeline <search-query> [--name "Song Remix"] [--no-open] [--viz]
#
# Prerequisites:
#   - tidal-dl-ng (pip install tidal-dl-ng)
#   - demucs (pip install demucs)
#   - songsee (pip install songsee) — optional, for visualizations
#   - librosa, numpy, tidalapi (pip install -r requirements.txt)
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_DIR="$(dirname "$SCRIPT_DIR")"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Defaults
QUERY=""
NAME=""
NO_OPEN=""
DO_VIZ=""

# Parse args
while [[ $# -gt 0 ]]; do
    case $1 in
        --name)
            NAME="$2"
            shift 2
            ;;
        --no-open)
            NO_OPEN="--no-open"
            shift
            ;;
        --viz)
            DO_VIZ="1"
            shift
            ;;
        --help|-h)
            echo "Usage: remix-pipeline <search-query> [--name \"Song Remix\"] [--no-open] [--viz]"
            echo ""
            echo "Full DAS remix pipeline:"
            echo "  1. Search Tidal for the track"
            echo "  2. Download HQ audio via tidal-dl-ng"
            echo "  3. Detect BPM + key"
            echo "  4. Split into stems via demucs"
            echo "  5. Scaffold Ableton project"
            echo "  6. Generate analysis visualizations (optional)"
            echo ""
            echo "Options:"
            echo "  --name NAME    Project name (default: track name)"
            echo "  --no-open      Don't auto-open Ableton project"
            echo "  --viz          Generate songsee visualizations (off by default)"
            exit 0
            ;;
        *)
            if [[ -z "$QUERY" ]]; then
                QUERY="$1"
            else
                QUERY="$QUERY $1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$QUERY" ]]; then
    echo -e "${RED}Error: No search query provided${NC}"
    echo "Usage: remix-pipeline <search-query> [--name \"Song Remix\"]"
    exit 1
fi

echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${CYAN}║       DAS REMIX PIPELINE v1.0            ║${NC}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════╝${NC}"
echo ""

# ─── Step 1: Search Tidal ────────────────────────────────────────────
echo -e "${BOLD}${BLUE}[1/6]${NC} ${BOLD}Searching Tidal for:${NC} ${QUERY}"
echo ""

TIDAL_URL=$("$SCRIPT_DIR/tidal-search" --first "$QUERY" 2>/dev/null) || {
    echo -e "${RED}Error: Tidal search failed. Showing results:${NC}"
    "$SCRIPT_DIR/tidal-search" "$QUERY" || true
    echo ""
    read -p "Enter Tidal URL manually: " TIDAL_URL
}

echo -e "${GREEN}  ✓ Found:${NC} $TIDAL_URL"
echo ""

# ─── Step 2: Download from Tidal ─────────────────────────────────────
echo -e "${BOLD}${BLUE}[2/6]${NC} ${BOLD}Downloading from Tidal...${NC}"

# Find the download directory
TIDAL_DL_DIR="$HOME/Music/tidal-dl"
mkdir -p "$TIDAL_DL_DIR"

# Get list of files before download
BEFORE_FILES=$(find "$TIDAL_DL_DIR" -maxdepth 3 -type f \( -name "*.flac" -o -name "*.mp3" -o -name "*.m4a" \) 2>/dev/null | sort)

tidal-dl-ng dl "$TIDAL_URL" 2>&1 | tail -5

# Find the newly downloaded file
AFTER_FILES=$(find "$TIDAL_DL_DIR" -maxdepth 3 -type f \( -name "*.flac" -o -name "*.mp3" -o -name "*.m4a" \) 2>/dev/null | sort)
AUDIO_FILE=$(comm -13 <(echo "$BEFORE_FILES") <(echo "$AFTER_FILES") | head -1)

if [[ -z "$AUDIO_FILE" ]]; then
    # Fallback: find most recently modified file
    AUDIO_FILE=$(find "$TIDAL_DL_DIR" -maxdepth 3 -type f \( -name "*.flac" -o -name "*.mp3" -o -name "*.m4a" \) -newer /tmp/.remix-pipeline-start 2>/dev/null | head -1)
fi

if [[ -z "$AUDIO_FILE" ]]; then
    echo -e "${RED}Error: Could not find downloaded file${NC}"
    echo "Check $TIDAL_DL_DIR for the download and run remaining steps manually."
    exit 1
fi

echo -e "${GREEN}  ✓ Downloaded:${NC} $(basename "$AUDIO_FILE")"
echo ""

# ─── Step 3: Detect BPM + Key ────────────────────────────────────────
echo -e "${BOLD}${BLUE}[3/6]${NC} ${BOLD}Analyzing track...${NC}"

TRACK_INFO=$("$SCRIPT_DIR/track-info" "$AUDIO_FILE")
echo "$TRACK_INFO" | sed 's/^/  /'

BPM=$(echo "$TRACK_INFO" | grep "BPM:" | awk '{print $2}')
KEY=$(echo "$TRACK_INFO" | grep "Key:" | cut -d: -f2- | xargs)
DURATION=$(echo "$TRACK_INFO" | grep "Duration:" | awk '{print $2}')

echo ""

# ─── Step 4: Split Stems ─────────────────────────────────────────────
echo -e "${BOLD}${BLUE}[4/6]${NC} ${BOLD}Splitting stems with demucs...${NC}"
echo -e "${YELLOW}  (this takes a few minutes)${NC}"

DEMUCS_OUTPUT="$HOME/Music/tidal-dl/separated"
demucs -n htdemucs --mp3 "$AUDIO_FILE" -o "$DEMUCS_OUTPUT" 2>&1 | tail -3

# Find the stems directory
TRACK_BASENAME=$(basename "$AUDIO_FILE" | sed 's/\.[^.]*$//')
STEMS_DIR="$DEMUCS_OUTPUT/htdemucs/$TRACK_BASENAME"

if [[ ! -d "$STEMS_DIR" ]]; then
    # Try to find it
    STEMS_DIR=$(find "$DEMUCS_OUTPUT/htdemucs" -maxdepth 1 -type d -newer "$AUDIO_FILE" | tail -1)
fi

if [[ ! -d "$STEMS_DIR" ]]; then
    echo -e "${RED}Error: Could not find stems directory${NC}"
    exit 1
fi

echo -e "${GREEN}  ✓ Stems:${NC} $STEMS_DIR"
ls "$STEMS_DIR" | sed 's/^/    /'
echo ""

# ─── Step 5: Scaffold Ableton Project ────────────────────────────────
echo -e "${BOLD}${BLUE}[5/6]${NC} ${BOLD}Creating Ableton project...${NC}"

SCAFFOLD_ARGS=("$STEMS_DIR" --bpm "$BPM")
if [[ -n "$NAME" ]]; then
    SCAFFOLD_ARGS+=(--name "$NAME")
fi
if [[ -n "$NO_OPEN" ]]; then
    SCAFFOLD_ARGS+=(--no-open)
fi

"$SCRIPT_DIR/scaffold-remix" "${SCAFFOLD_ARGS[@]}" 2>&1 | sed 's/^/  /'
echo ""

# ─── Step 6: Visualizations ──────────────────────────────────────────
VIZ_FILE=""
if [[ -n "$DO_VIZ" ]]; then
    echo -e "${BOLD}${BLUE}[6/6]${NC} ${BOLD}Generating visualizations...${NC}"

    if command -v songsee &>/dev/null; then
        VIZ_FILE="${AUDIO_FILE%.*}_analysis.png"
        songsee "$AUDIO_FILE" --viz spectrogram,mel,chroma,hpss,selfsim -o "$VIZ_FILE" 2>&1 | tail -3 || {
            echo -e "${YELLOW}  ⚠ songsee visualization failed (non-critical)${NC}"
            VIZ_FILE=""
        }
        if [[ -n "$VIZ_FILE" && -f "$VIZ_FILE" ]]; then
            echo -e "${GREEN}  ✓ Visualization:${NC} $VIZ_FILE"
        fi
    else
        echo -e "${YELLOW}  ⚠ songsee not installed, skipping visualizations${NC}"
    fi
else
    echo -e "${BOLD}${BLUE}[6/6]${NC} ${BOLD}Skipping visualizations (use --viz to enable)${NC}"
fi

echo ""

# ─── Summary ─────────────────────────────────────────────────────────
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${CYAN}║           REMIX PIPELINE COMPLETE        ║${NC}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════╝${NC}"
echo ""
echo -e "${BOLD}  Track:${NC}    $(basename "$AUDIO_FILE")"
echo -e "${BOLD}  BPM:${NC}      $BPM"
echo -e "${BOLD}  Key:${NC}      $KEY"
echo -e "${BOLD}  Duration:${NC} $DURATION"
echo -e "${BOLD}  Stems:${NC}    $STEMS_DIR"
echo -e "${BOLD}  Project:${NC}  ~/Documents/das/remix-projects/$(basename "$STEMS_DIR")/"
if [[ -n "$VIZ_FILE" ]]; then
echo -e "${BOLD}  Viz:${NC}      $VIZ_FILE"
fi
echo ""
echo -e "${GREEN}🎵 Ready to remix!${NC}"
