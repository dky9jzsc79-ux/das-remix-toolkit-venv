#!/usr/bin/env python3
"""Detect BPM, key, and duration of an audio track.

Uses librosa for audio analysis and Krumhansl-Schmuckler algorithm for key detection.

Usage:
    track-info <audio-file> [--json]
"""
import sys
import librosa
import numpy as np
import warnings
warnings.filterwarnings("ignore")

if len(sys.argv) < 2:
    print("Usage: track-info <audio-file> [--json]")
    sys.exit(1)

track = sys.argv[1]
y, sr = librosa.load(track, sr=None)

# BPM
tempo, _ = librosa.beat.beat_track(y=y, sr=sr)
bpm = float(tempo) if np.isscalar(tempo) else float(tempo[0])

# Key detection via chroma (Krumhansl-Schmuckler)
chroma = librosa.feature.chroma_cqt(y=y, sr=sr)
chroma_mean = chroma.mean(axis=1)
keys = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B']

major_profile = np.array([6.35, 2.23, 3.48, 2.33, 4.38, 4.09, 2.52, 5.19, 2.39, 3.66, 2.29, 2.88])
minor_profile = np.array([6.33, 2.68, 3.52, 5.38, 2.60, 3.53, 2.54, 4.75, 3.98, 2.69, 3.34, 3.17])

def rotate(arr, n):
    return np.roll(arr, n)

best_major = max(range(12), key=lambda i: np.corrcoef(chroma_mean, rotate(major_profile, i))[0,1])
best_minor = max(range(12), key=lambda i: np.corrcoef(chroma_mean, rotate(minor_profile, i))[0,1])
major_corr = np.corrcoef(chroma_mean, rotate(major_profile, best_major))[0,1]
minor_corr = np.corrcoef(chroma_mean, rotate(minor_profile, best_minor))[0,1]

if major_corr > minor_corr:
    detected_key = f"{keys[best_major]} Major"
else:
    detected_key = f"{keys[best_minor]} Minor"

duration = len(y) / sr
mins = int(duration // 60)
secs = int(duration % 60)

print(f"BPM: {bpm:.1f}")
print(f"Key: {detected_key}")
print(f"Duration: {mins}:{secs:02d}")

# JSON output if --json flag
if "--json" in sys.argv:
    import json
    print(json.dumps({"bpm": round(bpm, 1), "key": detected_key, "duration_sec": round(duration, 1)}))
