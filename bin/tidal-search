#!/usr/bin/env python3
"""Search Tidal for tracks and return track URLs.

Reads OAuth token from ~/.config/tidal_dl_ng/token.json (shared with tidal-dl-ng).

Usage:
    tidal-search "Dirty AF1s Alexander 23"
    tidal-search --limit 5 "some query"
"""
import sys
import os
import json
import argparse
import tidalapi

def load_token():
    """Load OAuth token from tidal-dl-ng config."""
    token_path = os.path.expanduser("~/.config/tidal_dl_ng/token.json")
    if not os.path.exists(token_path):
        print(f"Error: Token file not found at {token_path}", file=sys.stderr)
        print("Run tidal-dl-ng first to authenticate.", file=sys.stderr)
        sys.exit(1)
    with open(token_path) as f:
        return json.load(f)

def main():
    parser = argparse.ArgumentParser(description="Search Tidal for tracks")
    parser.add_argument("query", help="Search query")
    parser.add_argument("--limit", type=int, default=3, help="Number of results (default: 3)")
    parser.add_argument("--first", action="store_true", help="Only print the first result URL")
    args = parser.parse_args()

    token_data = load_token()

    session = tidalapi.Session()
    # Login with stored token
    try:
        session.load_oauth_session(
            token_type=token_data.get("token_type", "Bearer"),
            access_token=token_data["access_token"],
            refresh_token=token_data.get("refresh_token"),
            expiry_time=token_data.get("expiry_time")
        )
    except Exception as e:
        print(f"Error authenticating with Tidal: {e}", file=sys.stderr)
        print("Your token may be expired. Re-authenticate with tidal-dl-ng.", file=sys.stderr)
        sys.exit(1)

    if not session.check_login():
        print("Error: Tidal session not valid. Re-authenticate with tidal-dl-ng.", file=sys.stderr)
        sys.exit(1)

    results = session.search(args.query, models=[tidalapi.media.Track], limit=args.limit)
    tracks = results.get("tracks", results.get("top_hit", []))

    if not tracks:
        print("No results found.", file=sys.stderr)
        sys.exit(1)

    if args.first:
        track = tracks[0]
        print(f"https://tidal.com/browse/track/{track.id}")
        return

    for i, track in enumerate(tracks):
        artists = ", ".join(a.name for a in track.artists)
        url = f"https://tidal.com/browse/track/{track.id}"
        duration_m = track.duration // 60
        duration_s = track.duration % 60
        print(f"{i+1}. {track.name} — {artists} [{duration_m}:{duration_s:02d}]")
        print(f"   {url}")
        if i < len(tracks) - 1:
            print()

if __name__ == "__main__":
    main()
